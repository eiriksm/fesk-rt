{
  "name": "fesk-rt",
  "version": "0.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eiriksm/fesk-rt.git"
  },
  "exports": {
    ".": {
      "import": "./dist-lib/fesk-rt.js",
      "types": "./dist-lib/index.d.ts"
    }
  },
  "files": [
    "dist-lib/"
  ],
  "scripts": {
    "type-check": "tsc --noEmit",
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json && mkdir -p dist-lib/decoder && cp src/lib/decoder/index.d.ts dist-lib/decoder/index.d.ts",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "start": "vite preview --host 0.0.0.0 --port 4173",
    "prettier-check": "prettier --check --log-level debug \"src/**/*.{ts,tsx}\" cypress/**/*.js",
    "lint": "eslint . --max-warnings=0",
    "unit": "vitest run",
    "test": "npm run unit && npm run type-check && npm run prettier-check"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cypress": "^15.14.2",
    "eslint": "^9.39.2",
    "eslint-plugin-cypress": "^6.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
